+  public rotateSelectedElements: ExcalidrawImperativeAPI["rotateSelectedElements"] =
+    (angleDelta, opts = {}) => {
+      const selectedElements = this.scene.getSelectedElements(this.state);
+
+      if (!selectedElements.length) {
+        return false;
+      }
+
+      const elementsMap = this.scene.getNonDeletedElementsMap();
+      const [x1, y1, x2, y2] =
+        opts.center || selectedElements.length > 1
+          ? getCommonBounds(selectedElements, elementsMap)
+          : getElementAbsoluteCoords(selectedElements[0], elementsMap);
+      const centerX = opts.center?.x ?? (x1 + x2) / 2;
+      const centerY = opts.center?.y ?? (y1 + y2) / 2;
+      const targetAngle =
+        selectedElements.length === 1
+          ? selectedElements[0].angle + angleDelta
+          : angleDelta;
+      const pointerAngle = targetAngle - (5 * Math.PI) / 2;
+      const pointerX = centerX + Math.cos(pointerAngle) * 100;
+      const pointerY = centerY + Math.sin(pointerAngle) * 100;
+
+      const rotated = transformElements(
+        new Map(selectedElements.map((element) => [element.id, element])),
+        "rotation",
+        selectedElements,
+        this.scene,
+        opts.shouldRotateWithDiscreteAngle ?? false,
+        false,
+        false,
+        pointerX,
+        pointerY,
+        centerX,
+        centerY,
+      );
+
+      if (rotated) {
+        this.scene.triggerUpdate();
+      }
+
+      return rotated;
+    };
+
+  public setActiveLinearElement: ExcalidrawImperativeAPI["setActiveLinearElement"] =
+    (elementId, opts = {}) => {
+      if (elementId === null) {
+        this.setState({ selectedLinearElement: null });
+        return true;
+      }
+
+      const element = this.scene.getNonDeletedElementsMap().get(elementId);
+      if (!element || !isLinearElement(element)) {
+        return false;
+      }
+
+      const isEditing = opts.isEditing ?? false;
+      const pointIndex = Math.max(
+        0,
+        Math.min(
+          opts.pointIndex ?? element.points.length - 1,
+          element.points.length - 1,
+        ),
+      );
+      const baseLinearElementEditor = new LinearElementEditor(
+        element,
+        this.scene.getNonDeletedElementsMap(),
+        isEditing,
+      );
+
+      this.setState((prevState) => ({
+        selectedElementIds: makeNextSelectedElementIds(
+          { [element.id]: true },
+          prevState,
+        ),
+        selectedLinearElement: {
+          ...baseLinearElementEditor,
+          selectedPointsIndices: isEditing ? [pointIndex] : null,
+          hoverPointIndex: opts.hoverPointIndex ?? -1,
+          initialState: {
+            ...baseLinearElementEditor.initialState,
+            lastClickedPoint: isEditing ? pointIndex : -1,
+          },
+        },
+      }));
+
+      return true;
+    };
+
+  public refreshTextElementDimensions: ExcalidrawImperativeAPI["refreshTextElementDimensions"] =
+    (elementIds) => {
+      const elementIdSet =
+        elementIds === undefined
+          ? null
+          : new Set(Array.isArray(elementIds) ? elementIds : [elementIds]);
+      const elements = this.scene.getNonDeletedElements();
+      let didRefresh = false;
+
+      for (const element of elements) {
+        if (!isTextElement(element)) {
+          continue;
+        }
+        if (elementIdSet && !elementIdSet.has(element.id)) {
+          continue;
+        }
+
+        redrawTextBoundingBox(
+          element,
+          getContainerElement(element, this.scene.getNonDeletedElementsMap()),
+          this.scene,
+        );
+        didRefresh = true;
+      }
+
+      if (didRefresh) {
+        this.scene.triggerUpdate();
+      }
+
+      return didRefresh;
+    };
+
+  public rerouteElbowArrow: ExcalidrawImperativeAPI["rerouteElbowArrow"] = (
+    elementId,
+  ) => {
+    const element = this.scene.getNonDeletedElementsMap().get(elementId);
+    if (!element || !isElbowArrow(element)) {
+      return false;
+    }
+
+    this.scene.mutateElement(
+      element,
+      updateElbowArrowPoints(
+        element,
+        this.scene.getNonDeletedElementsMap(),
+        {
+          points: [element.points[0], element.points[element.points.length - 1]],
+          fixedSegments: [],
+        },
+        {
+          isBindingEnabled: this.state.isBindingEnabled,
+          isMidpointSnappingEnabled: this.state.isMidpointSnappingEnabled,
+        },
+      ),
+    );
+    this.scene.triggerUpdate();
+    return true;
+  };
