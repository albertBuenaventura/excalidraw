{
  "compilerOptions": {
    "target": "ESNext",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "allowSyntheticDefaultImports": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "emitDeclarationOnly": true,
    "paths": {
      "@albertBuenaventura/common": ["./common/src/index.ts"],
      "@albertBuenaventura/common/*": ["./common/src/*"],
      "@albertBuenaventura/element": ["./element/src/index.ts"],
      "@albertBuenaventura/element/*": ["./element/src/*"],
      "@albertBuenaventura/excalidraw": ["./excalidraw/index.tsx"],
      "@albertBuenaventura/excalidraw/*": ["./excalidraw/*"],
      "@albertBuenaventura/math": ["./math/src/index.ts"],
      "@albertBuenaventura/math/*": ["./math/src/*"],
      "@albertBuenaventura/utils": ["./utils/src/index.ts"],
      "@albertBuenaventura/utils/*": ["./utils/src/*"],
      "@excalidraw/fractional-indexing": ["./fractional-indexing/src/index.ts"],
      "@excalidraw/fractional-indexing/*": ["./fractional-indexing/src/*"]
    }
  }
}
